# HTTP mode — set both to send metrics to the central server
SERVER_URL=https://your-server/api/v1/metrics
API_KEY=your-api-key-here

# Optional — defaults shown
HOST_LABEL=          # defaults to system hostname
COLLECT_INTERVAL=30  # seconds between collections
RETRY_ATTEMPTS=3     # max HTTP retries with exponential backoff

# File mode — used when SERVER_URL / API_KEY are not set
# Use "stdout" to print to standard output instead of a file
OUTPUT_FILE=/data/metrics.jsonl

# Docker container metrics (optional, auto-enabled)
# Mount the Docker socket to collect per-container CPU/memory:
#   docker run ... -v /var/run/docker.sock:/var/run/docker.sock:ro argoos-agent
# When the socket is present, the agent reports each running container's
# cpu_percent / memory_usage / memory_limit; otherwise the feature is skipped.
# Override the socket path only if it differs from the default:
DOCKER_SOCKET=/var/run/docker.sock
