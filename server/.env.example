APP_NAME="Argoos Server"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Database — MySQL 8
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=argoos
DB_USERNAME=argoos
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Queue — Horizon + Redis
QUEUE_CONNECTION=redis
HORIZON_PREFIX=argoos_horizon:

# Cache (use 'redis' in production with Docker, 'file' for local dev)
CACHE_STORE=file
CACHE_PREFIX=argoos_cache_

# Session (not used in Phase 1, kept for Phase 2 dashboard)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Broadcasting (not used in Phase 1)
BROADCAST_CONNECTION=log

# Mail (not used in Phase 1, kept for Phase 4 alerts)
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="argoos@example.com"
MAIL_FROM_NAME="Argoos"

FILESYSTEM_DISK=local

# Dashboard — Basic Auth
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# Alerts — recipient email for all alert notifications
DASHBOARD_ALERT_EMAIL=

# Telegram (not yet functional — Phase 6)
# TELEGRAM_BOT_TOKEN=

# Webhook (not yet functional — Phase 6)
# WEBHOOK_SECRET=
